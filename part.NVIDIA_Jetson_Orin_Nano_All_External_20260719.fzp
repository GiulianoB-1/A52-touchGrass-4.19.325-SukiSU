  <version>2</version>
  <author>OpenAI for Giuliano Basso</author>
  <title>NVIDIA Jetson Orin Nano Dev Kit - All External Connectors</title>
  <label>Jetson Orin Nano</label>
  <date>2026-07-19</date>
  <description>Jetson Orin Nano Developer Kit with the complete J12 40-pin header plus selectable microSD, USB-C data, four USB-A, Gigabit Ethernet, DisplayPort, DC power and two MIPI CSI camera connectors. External ports are symbolic single connection points for system-level wiring diagrams; DC power is split into VIN and GND.</description>
  <tags>
    <tag>NVIDIA</tag><tag>Jetson</tag><tag>Orin Nano</tag><tag>developer kit</tag><tag>single board computer</tag><tag>robotics</tag>
  </tags>
  <properties>
    <property name="family">NVIDIA Jetson</property>
    <property name="variant">Orin Nano Developer Kit</property>
    <property name="logic level">3.3 V</property>
    <property name="DC input">9-20 V center positive</property>
    <property name="USB-C">data only</property>
  </properties>
